---
import BaseLayout from '../layouts/BaseLayout.astro';
import GamesGrid from '../components/GamesGrid';
---

<BaseLayout title="Inicio">
  <!-- Hero -->
  <section class="relative overflow-hidden py-24 px-4 sm:px-6 text-center">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(251,191,36,0.12),transparent)]" />
    <div class="relative max-w-3xl mx-auto">
      <p class="text-amber-400 text-sm font-medium tracking-widest uppercase mb-4">Bienvenidos</p>
      <h1 class="font-display text-5xl sm:text-7xl font-black tracking-tight text-white mb-6">
        Board<span class="text-amber-400">Stuff</span>
      </h1>
      <p class="text-zinc-400 text-lg sm:text-xl leading-relaxed max-w-xl mx-auto">
        Reglas, personajes y mecánicas de los juegos de mesa de nuestro grupo. Todo en un solo lugar.
      </p>
    </div>
  </section>

  <!-- Games grid (fetch client-side para mostrar datos siempre frescos) -->
  <GamesGrid client:load />
</BaseLayout>
